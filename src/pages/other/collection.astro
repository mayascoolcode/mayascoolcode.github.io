				<li><a href="http://mizuno-junko.com/" target="_blank" rel="noopener noreferrer">Junko Minuzo</a></li>
				<li><a href="https://pinkmoondoll9shihtzu.neocities.org/" target="_blank" rel="noopener noreferrer">PMD9</a></li>
				<li><a href="https://y-hill.net/" target="_blank" rel="noopener noreferrer">Yan-Hill</a></li>
				<li><a href="https://axayacatl.neocities.org/" target="_blank" rel="noopener noreferrer">Axacatyl</a></li>
