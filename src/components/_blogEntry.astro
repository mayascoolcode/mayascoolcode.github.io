---
interface Props {
  blogTitle: string;
  blogDate: string;
}
const { blogTitle, blogDate } = Astro.props;
---
<div class="border border-accent text-bean bg-champagne p-5 my-5">
	<div class="border-b border-accent flex items-center justify-between mb-5">
    <h3>{blogTitle}</h3>
    <small>{blogDate}</small>
  </div>
  <div>
		<p><slot /></p>
  </div>
</div>